---
import Search from "../assets/search.svg";
---

<div
    id="command-palette-container"
    class="fixed inset-0 items-center justify-center hidden z-50"
>
    <div
        id="command-palette-backdrop"
        class="absolute inset-0 backdrop-blur-sm"
    >
    </div>

    <div
        id="command-palette"
        class="relative bg-card-background rounded-md w-120 max-w-[90vw] shadow-2xl overflow-hidden"
        style="animation: paletteIn 0.15s ease-out;"
    >
        <div class="flex items-center gap-3 px-4 py-3 border-b border-border">
            <Search />
            <input
                type="text"
                placeholder="Search commands..."
                class="focus:outline-0 w-full text-sm bg-transparent placeholder:text-muted-foreground"
            />
            <kbd
                class="text-xs text-muted-foreground bg-muted px-1.5 py-0.5 rounded shrink-0"
                >Esc</kbd
            >
        </div>

        <ul class="py-1.5 max-h-72 overflow-y-auto"></ul>

        <div
            class="px-4 py-2 border-t border-border flex gap-4 text-xs text-muted-foreground"
        >
            <span><kbd>↑↓</kbd> navigate</span>
            <span><kbd>↵</kbd> select</span>
            <span><kbd>Esc</kbd> close</span>
        </div>
    </div>
</div>

<footer
    class="fixed bottom-0 bg-muted/95 md:bg-muted/20 w-full flex justify-center md:pb-0 pb-1"
>
    <span class="text-sm text-muted-foreground"
        ><kbd class="hidden md:inline">ctrl + k</kbd><span
            id="mobile-open"
            class="inline md:hidden underline underline-offset-4 cursor-pointer"
        >
            tap here</span
        > for command palette</span
    >
</footer>

<style>
    @keyframes paletteIn {
        from {
            opacity: 0;
            transform: scale(0.97) translateY(-4px);
        }
        to {
            opacity: 1;
            transform: scale(1) translateY(0);
        }
    }
</style>

<script>
    import Sun from "../assets/sun.svg?raw";
    import Moon from "../assets/moon.svg?raw";
    import File from "../assets/file.svg?raw";
    import Mail from "../assets/mail.svg?raw";
    import Github from "../assets/github.svg?raw";
    import Linkedin from "../assets/linkedin.svg?raw";

    import { toggleTheme, getCurrentTheme } from "../utils/theme";

    const palette = document.querySelector("#command-palette")!;
    const container = document.querySelector("#command-palette-container")!;
    const backdrop = document.querySelector("#command-palette-backdrop")!;
    const mobileButton = document.querySelector("#mobile-open")!;
    const list = palette.querySelector("ul")!;
    const input = palette.querySelector("input")!;

    interface CommandPaletteItem {
        id: number;
        icon: string;
        name: string;
        action: () => void;
    }

    const items: CommandPaletteItem[] = [
        {
            id: 0,
            icon: Sun,
            name: "Change to light mode",
            action: () => toggleTheme(),
        },
        {
            id: 1,
            icon: Moon,
            name: "Change to dark mode",
            action: () => toggleTheme(),
        },
        {
            id: 2,
            icon: File,
            name: "Download CV",
            action: () => window.open("/portfolio/Agustin_Gil_CV.pdf"),
        },
        {
            id: 3,
            icon: Mail,
            name: "Email me",
            action: () => window.open("mailto:agustingilsosa@gmail.com"),
        },
        {
            id: 4,
            icon: Github,
            name: "Visit my GitHub",
            action: () => window.open("https://github.com/agilsosa"),
        },
        {
            id: 5,
            icon: Linkedin,
            name: "Visit my LinkedIn",
            action: () =>
                window.open(
                    "https://www.linkedin.com/in/agust%C3%ADn-gil-537522355/",
                ),
        },
    ];

    let filtered: CommandPaletteItem[] = [...items];
    let currentIndex = 0;

    function render() {
        list.innerHTML = "";

        if (filtered.length === 0) {
            const empty = document.createElement("li");
            empty.className =
                "px-4 py-6 text-sm text-muted-foreground text-center";
            empty.textContent = "No commands found.";
            list.appendChild(empty);
            return;
        }

        filtered.forEach((item, idx) => {
            const li = document.createElement("li");
            li.id = `item-${item.id}`;
            li.className = `hover:bg-muted mx-1.5 px-3 py-2 rounded text-sm cursor-pointer flex items-center gap-2 transition-colors ${
                idx === currentIndex ? "bg-muted" : ""
            }`;

            li.addEventListener("click", () => {
                item.action();
                close();
            });

            const iconWrapper = document.createElement("span");
            iconWrapper.className =
                "w-4 h-4 shrink-0 text-muted-foreground [&>svg]:w-4 [&>svg]:h-4";
            iconWrapper.innerHTML = item.icon;

            const btn = document.createElement("button");
            btn.className = "text-left flex-1 cursor-pointer";
            btn.textContent = item.name;

            li.appendChild(iconWrapper);
            li.appendChild(btn);
            list.appendChild(li);
        });

        const active = list.querySelector(
            `#item-${filtered[currentIndex]?.id}`,
        );
        active?.scrollIntoView({ block: "nearest" });
    }

    function filter(query: string) {
        const q = query.toLowerCase().trim();
        filtered = q
            ? items.filter((i) => i.name.toLowerCase().includes(q))
            : [...items];

        if (getCurrentTheme() === "light") {
            filtered = filtered.filter((f) => f.id != 0);
        }

        if (getCurrentTheme() === "dark") {
            filtered = filtered.filter((f) => f.id != 1);
        }

        currentIndex = 0;
        render();
    }

    function open() {
        filter("");
        input.value = "";
        container.classList.remove("hidden");
        container.classList.add("flex");
        input.focus();
    }

    function close() {
        container.classList.add("hidden");
        container.classList.remove("flex");
        input.value = "";
    }

    document.addEventListener("keydown", (e) => {
        const isOpen = container.classList.contains("flex");

        if ((e.ctrlKey || e.metaKey) && e.key.toLowerCase() === "k") {
            e.preventDefault();
            isOpen ? close() : open();
            return;
        }

        if (!isOpen) return;

        if (e.key === "Escape") {
            e.preventDefault();
            close();
            return;
        }

        if (e.key === "ArrowDown") {
            e.preventDefault();
            if (filtered.length === 0) return;
            currentIndex = (currentIndex + 1) % filtered.length;
            render();
            return;
        }

        if (e.key === "ArrowUp") {
            e.preventDefault();
            if (filtered.length === 0) return;
            currentIndex =
                (currentIndex - 1 + filtered.length) % filtered.length;
            render();
            return;
        }

        if (e.key === "Enter") {
            e.preventDefault();
            const selected = filtered[currentIndex];
            if (selected) {
                selected.action();
                close();
            }
            return;
        }
    });

    mobileButton.addEventListener("click", open);

    input.addEventListener("input", () => filter(input.value));

    backdrop.addEventListener("click", close);

    render();
</script>
