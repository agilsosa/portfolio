---
import Layout from "../layouts/Layout.astro";
import EducationSection from "../components/sections/EducationSection.astro";
import WorkSection from "../components/sections/WorkSection.astro";
import Contact from "../components/Contact.astro";
import CommandPalette from "../components/CommandPalette.astro";
---

<Layout>
	<header class="mb-4">
		<div class="inline-block">
			<h1
				class="name sm:text-5xl text-4xl font-bold tracking-wide border-r-4 border-solid w-full whitespace-nowrap overflow-hidden sm:h-[3.2rem] h-10"
			>
				Agustín Gil
			</h1>
		</div>
		<h2 class="mt-1 mb-2 font-bold">Systems Engineer - Web Developer</h2>
		<Contact />
	</header>
	<main>
		<p class="text-sm">
			I'm a Systems Engineer and Web Developer who enjoys working across
			the full stack, from the infrastructure that keeps things running to
			the interfaces people actually interact with. I like building things
			that are clean, practical, and make sense to use.
		</p>
		<WorkSection />
		<EducationSection />
	</main>
	<footer class="flex justify-center mt-2">
		<span class="text-sm text-muted"
			><kbd>ctrl + k</kbd> for command palette</span
		>
	</footer>

	<CommandPalette />
	<style>
		.name {
			animation:
				typing 2s steps(11),
				cursor 0.4s step-end infinite alternate;
		}

		@keyframes cursor {
			50% {
				border-color: transparent;
			}
		}

		@keyframes typing {
			from {
				width: 0;
			}
		}
	</style>
</Layout>
